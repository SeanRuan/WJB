{
  "name": "wujibackstage",
  "version": "0.1.0",
  "private": true,
  "description": "NestJS backend workspace for the mahjong game admin services.",
  "main": "dist/main.js",
  "scripts": {
    "build": "nest build",
    "start": "node dist/main.js",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "check": "tsc --noEmit",
    "check:secrets": "pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/check-secrets.ps1",
    "prisma:generate": "prisma generate",
    "prisma:pull": "prisma db pull"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.6",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.6",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.6",
    "@prisma/client": "^6.12.0",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "dotenv": "^16.6.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.10",
    "@nestjs/schematics": "^11.0.6",
    "@nestjs/testing": "^11.1.6",
    "@types/bcrypt": "^6.0.0",
    "@types/node": "^24.0.15",
    "@types/passport-jwt": "^4.0.1",
    "prisma": "^6.12.0",
    "typescript": "^5.8.3"
  }
}

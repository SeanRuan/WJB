{
  "name": "wujibackstage",
  "version": "0.1.0",
  "private": true,
  "description": "NestJS backend workspace for the mahjong game admin services.",
  "main": "dist/main.js",
  "scripts": {
    "build": "nest build",
    "start": "node dist/main.js",
    "dev:watch:build": "tsc -p tsconfig.build.json --watch --preserveWatchOutput",
    "dev:watch:serve": "nodemon --watch dist --ext js,json --delay 250ms --exec \"node dist/main.js\"",
    "start:dev:raw": "concurrently --restart-tries 999 --restart-after 1200 -n BUILD,APP -c cyan,green \"npm:dev:watch:build\" \"npm:dev:watch:serve\"",
    "start:dev": "pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/start-dev.ps1",
    "start:debug": "nest start --debug --watch",
    "check": "tsc --noEmit",
    "check:secrets": "pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/check-secrets.ps1",
    "smoke:reset-mock-state": "pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/reset-mock-state.ps1",
    "smoke:admin-disable": "pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/admin-disable-smoke.ps1",
    "smoke:core-cs": "pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/smoke-core-cs.ps1",
    "smoke:guild-approval-review": "pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/guild-approval-review-smoke.ps1",
    "smoke:guild-member": "pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/guild-member-smoke.ps1",
    "smoke:recharge-review": "pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/recharge-review-smoke.ps1",
    "prisma:generate": "prisma generate",
    "prisma:pull": "prisma db pull"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.6",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.6",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.6",
    "@prisma/client": "^6.12.0",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "dotenv": "^16.6.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.10",
    "@nestjs/schematics": "^11.0.6",
    "@nestjs/testing": "^11.1.6",
    "@types/bcrypt": "^6.0.0",
    "@types/node": "^24.0.15",
    "@types/passport-jwt": "^4.0.1",
    "concurrently": "^9.2.4",
    "nodemon": "^3.1.14",
    "prisma": "^6.12.0",
    "typescript": "^5.8.3"
  }
}
